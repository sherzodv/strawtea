DATABASE_URL=postgres://postgres:postgres@localhost:5432/strawtea
SUPABASE_JWT_ISSUER=https://your-project.supabase.co/auth/v1
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWT_JWKS_URL=https://your-project.supabase.co/auth/v1/.well-known/jwks.json
HTTP_ADDR=0.0.0.0:8080

# Prefer setting this in your shell instead of storing it in .env:
# export STRAWTEA_TWELVE_API_KEY=replace-me

# Required for real browser push notifications.
# Generate a P-256 key with:
# openssl ecparam -name prime256v1 -genkey -noout -out private.pem
# export STRAWTEA_VAPID_PRIVATE_KEY="$(cat private.pem)"
# export STRAWTEA_VAPID_SUBJECT=mailto:you@example.com
